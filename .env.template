# Copy this to .env and fill in your NEW tokens (NEVER commit .env!)

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_new_telegram_token_here

# OpenClaw Auth Token (from openclaw.json gateway section)
OPENCLAW_TOKEN=your_new_openclaw_token_here

# Brave Search API Key (from https://brave.com/search/api/)
BRAVE_API_KEY=your_new_brave_key_here

# CoinDesk API Key (if you get one)
COINDESK_API_KEY=your_coindesk_key_here

# CryptoPanic API Key (if you get one)
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here
